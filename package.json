{
  "name": "sendkit-workspace",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "oxlint . --deny-warnings",
    "line:fix": "oxlint . --fix",
    "build:core": "bun run --filter @neeraj_jangir/sendkit-core build",
    "build:cli": "bun run --filter @neeraj_jangir/sendkit build",
    "build:local-mcp": "bun run --filter @neeraj_jangir/sendkit-mcp build",
    "dev:cli": "bun run packages/cli/src/index.ts",
    "dev:local-mcp": "bun run packages/local-mcp/src/index.ts",
    "dev:remote-mcp": "bun run apps/remote-mcp/src/index.ts",
    "release:pack:core": "bun run --filter @neeraj_jangir/sendkit-core pack:dry",
    "release:pack:cli": "bun run --filter @neeraj_jangir/sendkit pack:dry",
    "release:pack:local-mcp": "bun run --filter @neeraj_jangir/sendkit-mcp pack:dry",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^26.0.1",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tsdown": "^0.22.3"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
